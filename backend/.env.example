# Copia este archivo a .env y ajusta los valores.

# OBLIGATORIO en producción: genera una con
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# True solo en desarrollo
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Contraseñas de las cuentas privadas (usadas por: python manage.py seed_users)
# Si se dejan vacías, se genera una aleatoria y se muestra una sola vez.
KENYI_PASSWORD=
JOEL_PASSWORD=

# PostgreSQL (opcional; si DB_NAME queda vacío se usa SQLite)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
